# Core API keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional observability: LangSmith tracing for multi-agent supervisor runs.
# When set, each run records routing, per-agent latency, retries, and outputs.
LANGSMITH_API_KEY=your_langsmith_api_key_here

# Optional LangSmith project name used to group traces in the LangSmith UI.
LANGCHAIN_PROJECT=llmops-research-assistant

OPENAI_API_KEY=
REDIS_URL=redis://redis:6379/0
MLFLOW_TRACKING_URI=http://mlflow:5000

# API authentication (set a strong random value in production)
API_KEY=

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Flower monitoring dashboard credentials (required when using docker-compose)
FLOWER_USER=admin
FLOWER_PASSWORD=

# Retrieval
SHARD_AGGREGATOR_URL=http://aggregator:8000
SHARD_URLS=http://shard-0:8001,http://shard-1:8001,http://shard-2:8001,http://shard-3:8001
INDEX_PATH=data/faiss.index
META_PATH=data/metadata.json

# Embeddings / models
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
SYNTH_BACKEND=openai
VLLM_MODEL=meta-llama/Llama-3-8B-Instruct

# AWS
AWS_REGION=us-east-1
S3_BUCKET=your-llmops-bucket
CW_NAMESPACE=LLMOps/Inference
CW_LOG_GROUP=/llmops/production
ENVIRONMENT=development
